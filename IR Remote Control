#include <IRremote.h>
 
int in1 = 2;
int in2 = 3;
int in3 = 4;
int in4 = 5;
 
int IRpin=8;
IRrecv IR(IRpin);
decode_results cmd;
 
void setup(){
  Serial.begin(9600);
  IR.enableIRIn();
  pinMode(in1, OUTPUT); //right wheels forward
  pinMode(in2, OUTPUT); //right wheels backward
  pinMode(in3, OUTPUT); //left wheels forward
  pinMode(in4, OUTPUT); //left wheels backward
}
 
void loop(){
  while(IR.decode(&cmd)==0){}
  Serial.println(cmd.value,HEX);
  IR.resume();
  if(cmd.value==0xFF18E7){ //forward
    digitalWrite(in1, HIGH);
    digitalWrite(in3, HIGH);
    delay(500);
  }
  if(cmd.value==0xFF4AB5){ //reverse
    digitalWrite(in2, HIGH);
    digitalWrite(in4, HIGH);
    delay(500);
  }
  if(cmd.value==0xFF10EF){ //left-forward
    digitalWrite(in3, HIGH);
    delay(500);
  }
  if(cmd.value==0xFF5AA5){ //right-forward
    digitalWrite(in1, HIGH);
    delay(500);
  }
  if(cmd.value==0xFF38C7){ //stop
    digitalWrite(in1, LOW);
    digitalWrite(in3, LOW);
    digitalWrite(in2, LOW);
    digitalWrite(in4, LOW);
    delay(500);
  }
  }
